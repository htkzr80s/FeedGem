<Window x:Class="FeedGem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="FeedGem" Height="600" Width="1000">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="350"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TreeView x:Name="FeedTreeView" Grid.Column="0" Margin="5" 
                      PreviewMouseRightButtonDown="FeedTreeView_PreviewMouseRightButtonDown"
                      AllowDrop="True"
                      PreviewMouseLeftButtonDown="FeedTreeView_PreviewMouseLeftButtonDown"
                      PreviewMouseMove="FeedTreeView_PreviewMouseMove"
                      DragOver="FeedTreeView_DragOver"
                      Drop="FeedTreeView_Drop">

                <TreeView.Resources>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Padding" Value="2,4"/>
                    </Style>
                </TreeView.Resources>

                <TreeView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="新しいフォルダ" Click="CreateFolder_Click"/>
                        <Separator/>
                        <MenuItem Header="OPMLをインポート" Click="ImportOpml_Click"/>
                        <MenuItem Header="OPMLをエクスポート" Click="ExportOpml_Click"/>
                        <Separator/>
                        <MenuItem Header="名前を変更" Click="RenameFeed_Click"/>
                        <MenuItem Header="フォルダを移動" Click="MoveFolder_Click"/>
                        <Separator/>
                        <MenuItem Header="削除" Click="DeleteFeed_Click" Foreground="Red"/>
                    </ContextMenu>
                </TreeView.ContextMenu>
            </TreeView>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="LightGray"/>

            <ListView x:Name="ArticleListView" Grid.Column="2" Margin="5" SelectionChanged="ArticleListView_SelectionChanged">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="タイトル" Width="200">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Title}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="FontWeight" Value="Bold"/>
                                                <Setter Property="Foreground" Value="Black"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                        <Setter Property="FontWeight" Value="Normal"/>
                                                        <Setter Property="Foreground" Value="Gray"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="投稿日時" Width="120">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Date}" HorizontalAlignment="Right"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="LightGray"/>

            <Grid Grid.Column="4" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>
                <wv2:WebView2 x:Name="PreviewBrowser" Grid.Row="0"/>
                <Button x:Name="OpenBrowserButton" Grid.Row="1" Content="ブラウザで開く" Width="150" HorizontalAlignment="Right" Margin="0,5,0,0" Click="OpenBrowserButton_Click"/>
            </Grid>
        </Grid>

        <StatusBar Grid.Row="1">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <StatusBarItem Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="SearchBox" Width="250" Text="URLを入力してEnter..." 
                             Foreground="Gray" 
                             GotFocus="SearchBox_GotFocus" 
                             KeyDown="SearchBox_KeyDown"/>
                    <Button Content="⏎" Width="30" Margin="2,0,0,0" Click="UrlEnterButton_Click" ToolTip="購読を開始"/>
                </StackPanel>
            </StatusBarItem>

            <StatusBarItem Grid.Column="1" Margin="10,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="FilterBox" Width="180" Text="記事を検索..."
                             Foreground="Gray" 
                             GotFocus="FilterBox_GotFocus" 
                             TextChanged="FilterBox_TextChanged"/>
                    <Button x:Name="FilterClearButton" Content="✕" Width="30" Margin="2,0,0,0" Click="FilterClearButton_Click" ToolTip="検索をクリア"/>
                </StackPanel>
            </StatusBarItem>

            <StatusBarItem Grid.Column="2" HorizontalContentAlignment="Stretch">
                <TextBlock x:Name="LogTextBlock" Text="" Foreground="DimGray" Margin="10,0" TextTrimming="CharacterEllipsis"/>
            </StatusBarItem>

            <StatusBarItem Grid.Column="3">
                <TextBlock x:Name="LastUpdateTextBlock" Text="最終更新: --/--/-- --:--" Margin="0,0,5,0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
