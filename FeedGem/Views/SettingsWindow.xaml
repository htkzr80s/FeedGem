<Window x:Class="FeedGem.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="380"
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">

    <Grid Margin="20">
        <StackPanel>
            
            <!-- 言語ラベル -->
            <TextBlock x:Name="LangTextBlock"
                       Text="Language"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="5,0,5,15"/>

            <!-- 言語選択プルダウン -->
            <ComboBox x:Name="ComboLanguage"
                      Width="200"
                      Height="32"
                      HorizontalAlignment="Left"
                      Margin="5,0,5,15"
                      FontSize="14"
                      VerticalContentAlignment="Center"
                      SelectionChanged="ComboLanguage_SelectionChanged">
            </ComboBox>
            
            <!-- セクションタイトル -->
            <TextBlock x:Name="ThemeTextBlock"
                       Text="Theme"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="5,10,0,15"/>

            <!-- テーマ選択 -->
            <RadioButton x:Name="RadioAuto"
                         Content="Auto (Follow system settings)"
                         GroupName="Theme"
                         FontSize="14"
                         Margin="5"/>

            <RadioButton x:Name="RadioDark"
                         Content="Dark"
                         GroupName="Theme"
                         FontSize="14"
                         Margin="5"/>

            <RadioButton x:Name="RadioLight"
                         Content="Light"
                         GroupName="Theme"
                         FontSize="14"
                         Margin="5"/>
     
            <!-- ボタン -->
            <StackPanel Orientation="Horizontal"
                        Margin="0,30,0,0" HorizontalAlignment="Right" VerticalAlignment="Bottom">

                <Button Content="OK"
                        Width="100"
                        Height="38"
                        FontSize="14"
                        Margin="0,0,10,0"
                        Click="OkButton_Click"
                        IsDefault="True"/>

                <Button Content="Cancel"
                        Width="100"
                        Height="38"
                        FontSize="14"
                        Click="CancelButton_Click"
                        IsCancel="True"/>

            </StackPanel>

        </StackPanel>
    </Grid>
</Window>