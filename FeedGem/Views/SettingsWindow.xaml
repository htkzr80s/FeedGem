<Window x:Class="FeedGem.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings"
        Height="440"
        Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">

    <Grid Margin="20">
        <StackPanel>
            
            <!-- 言語ラベル -->
            <TextBlock x:Name="LangTextBlock"
                       Text="Language"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="5,0,5,15"/>

            <!-- 言語選択プルダウン -->
            <ComboBox x:Name="ComboLanguage"
                      Width="200"
                      Height="32"
                      HorizontalAlignment="Left"
                      Margin="5,0,5,15"
                      FontSize="14"
                      VerticalContentAlignment="Center"
                      SelectionChanged="ComboLanguage_SelectionChanged">
            </ComboBox>
            
            <!-- セクションタイトル -->
            <TextBlock x:Name="ThemeTextBlock"
                       Text="Theme"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="5,10,0,15"/>

            <!-- テーマ選択 -->
            <RadioButton x:Name="RadioAuto"
                         Content="Auto (Follow system settings)"
                         GroupName="Theme"
                         FontSize="14"
                         Margin="5"/>

            <RadioButton x:Name="RadioDark"
                         Content="Dark"
                         GroupName="Theme"
                         FontSize="14"
                         Margin="5"/>

            <RadioButton x:Name="RadioLight"
                         Content="Light"
                         GroupName="Theme"
                         FontSize="14"
                         Margin="5"/>
     
            <!-- ボタン -->
            <StackPanel Orientation="Horizontal"
                        Margin="0,30,0,0" HorizontalAlignment="Right" VerticalAlignment="Bottom">

                <Button Content="OK"
                        Width="100"
                        Height="38"
                        FontSize="14"
                        Margin="0,0,10,0"
                        Click="OkButton_Click"
                        IsDefault="True"/>

                <Button Content="Cancel"
                        Width="100"
                        Height="38"
                        FontSize="14"
                        Click="CancelButton_Click"
                        IsCancel="True"/>

            </StackPanel>

            <Separator Margin="0,15,0,10" Background="{DynamicResource BorderBrush}"/>

            <Grid Margin="25,5,5,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0" 
                       Source="pack://application:,,,/Resources/Icons/app.ico" 
                       Width="32" Height="32" 
                       VerticalAlignment="Center" Margin="0,0,10,0"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="FeedGem" FontWeight="Bold" FontSize="13" Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="{Binding AppVersion, FallbackValue='v1.0.0'}" Margin="8,0,0,0" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" VerticalAlignment="Bottom"/>
                    </StackPanel>
                    <TextBlock Text="Created by htkzr80s" FontSize="12" Foreground="{DynamicResource TextMutedBrush}"/>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Left">
                    <TextBlock FontSize="12">
                        <Hyperlink Click="GithubLink_Click" Foreground="{DynamicResource TextLinkBrush}" TextDecorations="Underline">View on GitHub</Hyperlink>
                    </TextBlock>
                    <TextBlock FontSize="12" Margin="0,2,0,0">
                        <Hyperlink Click="LicenseLink_Click" Foreground="{DynamicResource TextLinkBrush}" TextDecorations="Underline">Third-party Licenses</Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>

        </StackPanel>
    </Grid>
    
</Window>