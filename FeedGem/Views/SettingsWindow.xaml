<Window x:Class="FeedGem.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Options"
        Height="320"
        Width="420"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">

    <Grid Margin="20">
        <StackPanel>

            <!-- セクションタイトル -->
            <TextBlock Text="テーマ"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="5,0,0,10"/>

            <!-- テーマ選択 -->
            <RadioButton x:Name="RadioAuto"
                         Content="Auto（システム設定に従う）"
                         GroupName="Theme"
                         FontSize="14"
                         Margin="5"/>

            <RadioButton x:Name="RadioDark"
                         Content="Dark"
                         GroupName="Theme"
                         FontSize="14"
                         Margin="5"/>

            <RadioButton x:Name="RadioLight"
                         Content="Light"
                         GroupName="Theme"
                         FontSize="14"
                         Margin="5"/>

            <!-- 今後機能 -->
            <TextBlock Text="言語切り替え（今後実装予定）"
                       Foreground="{DynamicResource TextMutedBrush}"
                       FontSize="14"
                       Margin="5,20,5,10"/>

            <!-- ボタン -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,30,0,0">

                <Button Content="OK"
                        Width="100"
                        Height="38"
                        FontSize="14"
                        Margin="0,0,10,0"
                        Click="OkButton_Click"
                        IsDefault="True"/>

                <Button Content="Cancel"
                        Width="100"
                        Height="38"
                        FontSize="14"
                        Click="CancelButton_Click"
                        IsCancel="True"/>

            </StackPanel>

        </StackPanel>
    </Grid>
</Window>