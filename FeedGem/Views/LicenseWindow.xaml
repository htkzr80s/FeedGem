<Window x:Class="FeedGem.Views.LicenseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Third-party Licenses"
        Height="460" Width="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Libraries used in FeedGem"
                   Foreground="{DynamicResource TextMutedBrush}"
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

        <ListBox x:Name="LicenseListBox" 
         Grid.Row="1" 
         Background="Transparent" 
         BorderThickness="0"
         ScrollViewer.HorizontalScrollBarVisibility="Disabled">

            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{DynamicResource BorderBrush}" 
                                BorderThickness="0,0,0,1" 
                                Padding="10">
                                    <ContentPresenter />
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="Transparent"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="Transparent"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListBox.ItemContainerStyle>

            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding PackageId}" FontWeight="Bold" FontSize="15" Foreground="{DynamicResource TextBrush}"/>
                            <TextBlock Text="{Binding PackageVersion}" Margin="8,0,0,0" VerticalAlignment="Bottom" FontSize="13" Foreground="{DynamicResource TextMutedBrush}"/>
                        </StackPanel>

                        <TextBlock Text="{Binding Authors}" FontSize="14" Margin="0,2,0,0" Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="{Binding Copyright}" FontSize="13" Foreground="{DynamicResource TextMutedBrush}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <TextBlock FontSize="14">
                        <Hyperlink Click="UrlLink_Click" Tag="{Binding PackageProjectUrl}" Foreground="{DynamicResource TextLinkBrush}" TextDecorations="None">Project Site</Hyperlink>
                            </TextBlock>
                            <TextBlock Text=" | " Margin="5,0" Foreground="{DynamicResource TextMutedBrush}"/>
                            <TextBlock FontSize="14">
                        <Hyperlink Click="UrlLink_Click" Tag="{Binding LicenseUrl}" Foreground="{DynamicResource TextLinkBrush}" TextDecorations="None">
                            License: <Run Text="{Binding License}"/>
                        </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Button Grid.Row="2" Content="Close" Width="100" Height="30" Margin="0,15,0,0" HorizontalAlignment="Right" Click="CloseButton_Click"/>
    </Grid>
</Window>