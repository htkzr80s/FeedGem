<Window x:Class="FeedGem.Views.FeedSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="フィードの選択"
        Width="440"
        SizeToContent="Height"
        MaxHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 説明文 -->
        <TextBlock Grid.Row="0"
                   Text="複数のフィードが見つかりました。追加するものを選択してください。"
                   FontSize="14"
                   Margin="0,0,0,10"/>

        <!-- リスト（ここ重要） -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto">

            <ListBox x:Name="CandidateListBox">

                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
                    </Style>
                </ListBox.ItemContainerStyle>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <RadioButton
                            IsChecked="{Binding IsSelected, Mode=TwoWay}"
                            GroupName="FeedSelect"
                            HorizontalAlignment="Stretch"
                            Margin="4">

                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Type}" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding Url}" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </StackPanel>

                        </RadioButton>
                    </DataTemplate>
                </ListBox.ItemTemplate>

            </ListBox>
        </ScrollViewer>

        <!-- ボタン -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">

            <Button Content="OK"
                    Width="80"
                    Height="34"
                    FontSize="14"
                    Margin="0,10,10,0"
                    Click="OkButton_Click"/>

            <Button Content="Cancel"
                    Width="80"
                    FontSize="14"
                    Margin="0,10,0,0"
                    Click="CancelButton_Click"/>

        </StackPanel>
    </Grid>
</Window>