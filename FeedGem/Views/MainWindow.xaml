<Window x:Class="FeedGem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="clr-namespace:H.NotifyIcon;assembly=H.NotifyIcon.Wpf"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="FeedGem v1.0.0" Height="800" Width="1400"
        WindowStartupLocation="Manual"
        Background="{DynamicResource WindowBackgroundBrush}" 
        Foreground="{DynamicResource TextBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="colFeedTree" Width="250"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition x:Name="colArticleList" Width="450"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <tb:TaskbarIcon
                x:Name="TaskbarIcon"
                ToolTipText="FeedGem"
                IconSource="pack://application:,,,/Resources/app.ico"
                MenuActivation="RightClick"
                Visibility="Visible"/>

            <TreeView x:Name="FeedTreeView" Grid.Column="0" Margin="5" 
                      Background="{DynamicResource ControlBackgroundBrush}"
                      Foreground="{DynamicResource TextBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      PreviewMouseRightButtonDown="FeedTreeView_PreviewMouseRightButtonDown"
                      AllowDrop="True"
                      PreviewMouseLeftButtonDown="FeedTreeView_PreviewMouseLeftButtonDown"
                      PreviewMouseMove="FeedTreeView_PreviewMouseMove"
                      DragOver="FeedTreeView_DragOver"
                      Drop="FeedTreeView_Drop">

            </TreeView>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="{DynamicResource SplitterBrush}"/>

            <ListView x:Name="ArticleListView" Grid.Column="2" Margin="5"
                      Background="{DynamicResource ControlBackgroundBrush}"
                      Foreground="{DynamicResource TextBrush}"
                      BorderBrush="{DynamicResource BorderBrush}"
                      SelectionChanged="ArticleListView_SelectionChanged"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">

                <!-- ItemContainerStyleはテーマファイル側で一元管理済みなので削除 -->

                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="ブラウザで開く" Click="OpenBrowserButton_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="🌐"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="記事タイトルをコピー" Click="CopyTitle_Click" />
                        <MenuItem Header="URLをコピー" Click="CopyUrl_Click" />
                    </ContextMenu>
                </ListView.ContextMenu>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2,0,6" HorizontalAlignment="Stretch">
                            
                            <Grid x:Name="NormalContent">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" 
                                       Text="{Binding Title}" 
                                       FontSize="15" 
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,0,0,2">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                <Setter Property="FontWeight" Value="Normal"/>
                                                <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <Grid Grid.Row="1" HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- 左：フィード名 -->
                                <TextBlock Grid.Column="0"
                                       Text="{Binding FeedTitle}" 
                                       FontSize="13" 
                                       Foreground="{DynamicResource FeedTitleBrush}" 
                                       Margin="0,0,10,0"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"/>

                                <!-- 右：日時 -->
                                <TextBlock Grid.Column="1"
                                       Text="{Binding DisplayDate}" 
                                       FontSize="13" 
                                       Foreground="{DynamicResource TextMutedBrush}" 
                                       VerticalAlignment="Center"/>
                            </Grid>
                        </Grid>

                            <StackPanel x:Name="SkeletonContent" Visibility="Collapsed" Margin="0,2,0,0">
                                <Border Height="18" Width="250" Background="{DynamicResource SplitterBrush}" HorizontalAlignment="Left" CornerRadius="2" Margin="0,0,0,6"/>
                                <Border Height="14" Width="150" Background="{DynamicResource BorderBrush}" HorizontalAlignment="Left" CornerRadius="2"/>
                            </StackPanel>

                        </Grid>
                        
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding Title}" Value="_Loading_">
                                <Setter TargetName="NormalContent" Property="Visibility" Value="Collapsed"/>
                                <Setter TargetName="SkeletonContent" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="{DynamicResource SplitterBrush}"/>

            <Grid Grid.Column="4" Margin="5"
                  Background="{DynamicResource ControlBackgroundBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0" Background="{DynamicResource ControlBackgroundBrush}">
                    <wv2:WebView2 x:Name="PreviewBrowser"/>
                </Border>
                <Button x:Name="OpenBrowserButton" Grid.Row="1" Content="ブラウザで開く" Width="160" Height="32" FontSize="16" HorizontalAlignment="Right" Margin="0,5,0,0" Click="OpenBrowserButton_Click"/>
            </Grid>
        </Grid>

        <StatusBar Grid.Row="1" FontSize="14">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <StatusBarItem Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="SearchBox" Width="250" Text="URLを入力してEnter..." 
                            Foreground="{DynamicResource TextMutedBrush}" FontSize="14"
                            GotFocus="SearchBox_GotFocus" 
                            KeyDown="SearchBox_KeyDown"/>
                    <Button Content="⏎" Width="35" Margin="2,0,0,0" Click="UrlEnterButton_Click" ToolTip="購読を開始" FontSize="14"/>
                </StackPanel>
            </StatusBarItem>

            <StatusBarItem Grid.Column="1" Margin="10,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="FilterBox" Width="180" Text="記事を検索..."
                            Foreground="{DynamicResource TextMutedBrush}" FontSize="14"
                            GotFocus="FilterBox_GotFocus" 
                            TextChanged="FilterBox_TextChanged"/>
                    <Button x:Name="FilterClearButton" Content="✕" Width="35" Margin="2,0,0,0" Click="FilterClearButton_Click" ToolTip="検索をクリア" FontSize="14"/>

                </StackPanel>
            </StatusBarItem>

            <StatusBarItem Grid.Column="2" HorizontalContentAlignment="Stretch">
                <TextBlock x:Name="LogTextBlock" Text="" Foreground="{DynamicResource TextMutedBrush}" Margin="10,0" TextTrimming="CharacterEllipsis" FontSize="14"/>
            </StatusBarItem>

            <StatusBarItem Grid.Column="3">
                <TextBlock x:Name="LastUpdateTextBlock" Text="最終更新: --/--/-- --:--" Margin="0,0,5,0" FontSize="14"/>
            </StatusBarItem>
            <StatusBarItem Grid.Column="4">
                <Button Content="⚙️" Width="35" Margin="2,0,0,0"
                            Click="SettingsButton_Click" ToolTip="設定"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
