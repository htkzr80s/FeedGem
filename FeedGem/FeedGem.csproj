<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net10.0-windows</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<UseWPF>true</UseWPF>
		<PublishSingleFile>true</PublishSingleFile>
		<SelfContained>false</SelfContained>
		<RuntimeIdentifier>win-x64</RuntimeIdentifier>
		<IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
		<ApplicationIcon>Resources\Icons\app.ico</ApplicationIcon>
		<AllowUnsafeBlocks>True</AllowUnsafeBlocks>
		<Title>FeedGem</Title>
		<Authors>htkzr80s</Authors>
		<Product>FeedGem</Product>
		<Description>FeedGem</Description>
		<Copyright>© 2026 htkzr80s</Copyright>
		<NeutralLanguage>ja-JP</NeutralLanguage>
		<AssemblyVersion>1.0.1</AssemblyVersion>
		<Version>1.0.1</Version>
		<PackageId>FeedGem</PackageId>
		<FileVersion>1.0.1</FileVersion>
	</PropertyGroup>

	<ItemGroup>
	  <EmbeddedResource Include="Resources\licenses.json" />
	  <EmbeddedResource Include="Resources\Locales\en-US.json" />
	  <EmbeddedResource Include="Resources\Locales\ja-JP.json" />
	</ItemGroup>

	<ItemGroup>
	  <Resource Include="Resources\Icons\app.ico" />
	  <Resource Include="Resources\Icons\error.ico" />
	  <Resource Include="Resources\Icons\unread.ico" />
	  <Resource Include="Resources\Themes\DarkTheme.xaml" />
	  <Resource Include="Resources\Themes\LightTheme.xaml" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="H.NotifyIcon.Wpf" Version="2.4.1" />
		<PackageReference Include="HtmlAgilityPack" Version="1.12.4" />
		<PackageReference Include="Microsoft.Data.Sqlite" Version="10.0.8" />
		<PackageReference Include="Microsoft.Web.WebView2" Version="1.0.3967.48" />
		<PackageReference Include="System.ServiceModel.Syndication" Version="10.0.8" />
	</ItemGroup>
</Project>
