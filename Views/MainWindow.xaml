<Window x:Class="FeedGem.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="FeedGem" Height="800" Width="1400"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="450"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TreeView x:Name="FeedTreeView" Grid.Column="0" Margin="5" 
                      PreviewMouseRightButtonDown="FeedTreeView_PreviewMouseRightButtonDown"
                      AllowDrop="True"
                      PreviewMouseLeftButtonDown="FeedTreeView_PreviewMouseLeftButtonDown"
                      PreviewMouseMove="FeedTreeView_PreviewMouseMove"
                      DragOver="FeedTreeView_DragOver"
                      Drop="FeedTreeView_Drop">

                <TreeView.Resources>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="FontSize" Value="14"/>
                        <Setter Property="Padding" Value="2,4"/>
                    </Style>
                </TreeView.Resources>
            </TreeView>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="LightGray"/>

            <ListView x:Name="ArticleListView" Grid.Column="2" Margin="5" 
                      SelectionChanged="ArticleListView_SelectionChanged"
                      HorizontalContentAlignment="Stretch"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                
                <ListView.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="ブラウザで開く" Click="OpenBrowserButton_Click">
                            <MenuItem.Icon>
                                <TextBlock Text="🌐"/>
                            </MenuItem.Icon>
                        </MenuItem>
                        <Separator />
                        <MenuItem Header="記事タイトルをコピー" Click="CopyTitle_Click" />
                        <MenuItem Header="URLをコピー" Click="CopyUrl_Click" />
                    </ContextMenu>
                </ListView.ContextMenu>
                
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2,0,6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" 
                                       Text="{Binding Title}" 
                                       FontSize="15" 
                                       TextTrimming="CharacterEllipsis"
                                       Margin="0,0,0,2">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <Setter Property="Foreground" Value="Black"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsRead}" Value="True">
                                                <Setter Property="FontWeight" Value="Normal"/>
                                                <Setter Property="Foreground" Value="Gray"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>

                            <DockPanel Grid.Row="1">
                                <TextBlock Text="{Binding FeedTitle}" 
                                           FontSize="13" 
                                           Foreground="#0078D7" 
                                           Margin="0,0,10,0"
                                           VerticalAlignment="Center"/>

                                <TextBlock Text="{Binding DisplayDate}" 
                                           FontSize="13" 
                                           Foreground="DimGray" 
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="LightGray"/>

            <Grid Grid.Column="4" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="40"/>
                </Grid.RowDefinitions>
                <wv2:WebView2 x:Name="PreviewBrowser" Grid.Row="0"/>
                <Button x:Name="OpenBrowserButton" Grid.Row="1" Content="ブラウザで開く" Width="160" Height="32" FontSize="16" HorizontalAlignment="Right" Margin="0,5,0,0" Click="OpenBrowserButton_Click"/>
            </Grid>
        </Grid>

        <StatusBar Grid.Row="1" FontSize="14">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <StatusBarItem Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="SearchBox" Width="250" Text="URLを入力してEnter..." 
                            Foreground="Gray" FontSize="14"
                            GotFocus="SearchBox_GotFocus" 
                            KeyDown="SearchBox_KeyDown"/>
                    <Button Content="⏎" Width="35" Margin="2,0,0,0" Click="UrlEnterButton_Click" ToolTip="購読を開始" FontSize="14"/>
                </StackPanel>
            </StatusBarItem>

            <StatusBarItem Grid.Column="1" Margin="10,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="FilterBox" Width="180" Text="記事を検索..."
                            Foreground="Gray" FontSize="14"
                            GotFocus="FilterBox_GotFocus" 
                            TextChanged="FilterBox_TextChanged"/>
                    <Button x:Name="FilterClearButton" Content="✕" Width="35" Margin="2,0,0,0" Click="FilterClearButton_Click" ToolTip="検索をクリア" FontSize="14"/>
                </StackPanel>
            </StatusBarItem>

            <StatusBarItem Grid.Column="2" HorizontalContentAlignment="Stretch">
                <TextBlock x:Name="LogTextBlock" Text="" Foreground="DimGray" Margin="10,0" TextTrimming="CharacterEllipsis" FontSize="14"/>
            </StatusBarItem>

            <StatusBarItem Grid.Column="3">
                <TextBlock x:Name="LastUpdateTextBlock" Text="最終更新: --/--/-- --:--" Margin="0,0,5,0" FontSize="14"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
