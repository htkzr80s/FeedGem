<Window x:Class="FeedGem.Views.FeedSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="フィードの選択" Height="300" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="複数のフィードが見つかりました。追加するものを選択してください。" Margin="0,0,0,10"/>

        <ListBox x:Name="CandidateListBox">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4">

                        <RadioButton 
                            IsChecked="{Binding IsSelected, Mode=TwoWay}"
                            GroupName="FeedSelect">
                        <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="Bold"/>

                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding Type}" Foreground="Gray" Margin="0,0,10,0"/>
                                    <TextBlock Text="{Binding Url}" Foreground="Gray" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </StackPanel>
                        </RadioButton>

                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="OK" Width="80" Margin="0,0,10,0" Click="OkButton_Click"/>
            <Button Content="キャンセル" Width="80" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
